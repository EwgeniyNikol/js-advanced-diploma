{
  "extends": "airbnb-base",
  "env": {
    "browser": true,
    "jest": true,
    "es6": true
  },
  "rules": {
    "no-new": "off",
    "import/prefer-default-export": "off",
    "class-methods-use-this": "off",
    "no-unused-vars": ["error", { "argsIgnorePattern": "^_" }],
    "no-plusplus": "off",
    "no-restricted-syntax": "off",
    "no-await-in-loop": "off",
    "no-mixed-operators": "off",
    "radix": "off",
    "brace-style": "off",
    "max-len": "off",
    "no-empty": "off",
    "import/extensions": "off"
  }
}